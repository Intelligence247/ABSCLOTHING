# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=5050
# Comma-separated for production, e.g. https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:3000

# MongoDB connection string (Atlas: add your IP under Network Access → IP Access List)

MONGO_URI=mongodb+srv://sheltersetters_user:HrX7pwyKifL98LQI@cluster0.bdnfzgo.mongodb.net/test?retryWrites=true&w=majority

# Optional: driver only accepts 4 or 6. Leave unset for OS default (recommended for Atlas).
# If you must force IPv4 on broken IPv6 networks: MONGODB_CONNECT_FAMILY=4
# MONGODB_CONNECT_FAMILY=
# Optional retries (transient DNS / server selection): MONGODB_CONNECT_RETRIES=3, MONGODB_RETRY_DELAY_MS=2000

# Public URL of this API (used for links in emails if extended)
BACKEND_PUBLIC_URL=http://localhost:5050

# JWT — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Gmail (or other SMTP) — app password for Gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME="ABSCLOTHING Team"
# Optional: additional admin inboxes for contact-form notifications (comma-separated)
# CONTACT_ADMIN_EMAILS=owner@absclothing.ng,support@absclothing.ng

# Cloudinary — dashboard credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# One-time / bootstrap admin registration — strong unique secret
ADMIN_REGISTRATION_SECRET=change-me-admin-bootstrap-secret

# Optional overrides for `npm run seed` (defaults shown in scripts/seed.js console output)
# SEED_ADMIN_EMAIL=admin@absclothing.local
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_CUSTOMER_EMAIL=customer@absclothing.local
# SEED_CUSTOMER_PASSWORD=Customer123!

# Optional: if set, PUT /api/orders/:id/pay accepts header x-webhook-secret: <value>
# Otherwise the caller must be JWT-authenticated and own the order (or be admin).
# PAYMENT_WEBHOOK_SECRET=

# Bank transfer checkout defaults (merged with MongoDB StoreSettings when admin saves via dashboard / PUT /api/store/admin/payment-settings)
BANK_NAME=
BANK_ACCOUNT_NAME=
# Or BANK_ACCOUNT_HOLDER=
BANK_ACCOUNT_NUMBER=
# Aliases also accepted: BANK_ACCOUNT_NO, ACCOUNT_NUMBER
# Optional narration hint for customers (plain text)
# BANK_PAYMENT_REFERENCE_HINT=

# Next.js (.env.local) — for when the storefront calls this API (not read by Node here)
# NEXT_PUBLIC_API_URL=http://localhost:5050
