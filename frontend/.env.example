NEXT_PUBLIC_API_URL=http://localhost:5050

# Production: set to your deployed API URL. The backend CORS_ORIGIN must include this site’s origin
# (e.g. https://your-store.vercel.app) — see backend env.example.

# Bank transfer details for checkout are read from the backend (.env): BANK_NAME, BANK_ACCOUNT_NAME,
# BANK_ACCOUNT_NUMBER, optional BANK_PAYMENT_REFERENCE_HINT — exposed via GET /api/store/payment-info
